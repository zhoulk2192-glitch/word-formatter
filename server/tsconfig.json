{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../.generated/server",
    "tsBuildInfoFile": "../.generated/server.tsbuildinfo"
  },
  "include": ["src"],
  "references": [{ "path": "../shared" }]
}
