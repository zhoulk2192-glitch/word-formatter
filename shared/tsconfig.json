{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "tsBuildInfoFile": "../.generated/shared.tsbuildinfo",
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "outDir": "../.generated/shared"
  },
  "include": ["*.ts"]
}
